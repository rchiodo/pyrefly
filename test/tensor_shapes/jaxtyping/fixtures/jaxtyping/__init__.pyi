# Stub file for jaxtyping dtype wrapper classes.
# These are recognized by Pyrefly's jaxtyping annotation parser via
# is_jaxtyping_wrapper() and converted to TensorType at parse time.

from typing import Generic, TypeVar

_Array = TypeVar("_Array")
_Shape = TypeVar("_Shape")

class Float(Generic[_Array, _Shape]): ...
class Float16(Generic[_Array, _Shape]): ...
class Float32(Generic[_Array, _Shape]): ...
class Float64(Generic[_Array, _Shape]): ...
class BFloat16(Generic[_Array, _Shape]): ...
class Int(Generic[_Array, _Shape]): ...
class Int8(Generic[_Array, _Shape]): ...
class Int16(Generic[_Array, _Shape]): ...
class Int32(Generic[_Array, _Shape]): ...
class Int64(Generic[_Array, _Shape]): ...
class UInt(Generic[_Array, _Shape]): ...
class UInt8(Generic[_Array, _Shape]): ...
class UInt16(Generic[_Array, _Shape]): ...
class UInt32(Generic[_Array, _Shape]): ...
class UInt64(Generic[_Array, _Shape]): ...
class Bool(Generic[_Array, _Shape]): ...
class Num(Generic[_Array, _Shape]): ...
class Shaped(Generic[_Array, _Shape]): ...
class Complex(Generic[_Array, _Shape]): ...
class Complex64(Generic[_Array, _Shape]): ...
class Complex128(Generic[_Array, _Shape]): ...
class Inexact(Generic[_Array, _Shape]): ...
